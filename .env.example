PORT=3010
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/medsphere_ai
AI_PROVIDER_MODE=stub

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=whisper-1

CORE_SERVICE_URL=http://localhost:4000
INTERNAL_API_KEY=
MAX_AUDIO_FILE_SIZE_MB=25

# Docker Compose host-port overrides
MONGODB_PORT=27017
REDIS_PORT=6379

# Used only by docker-compose.yml when Core Service runs on the host machine.
CORE_SERVICE_URL_DOCKER=http://host.docker.internal:4000
