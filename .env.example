PORT=3010
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:5173

MONGODB_URI=mongodb://localhost:27019/medsphere_ai
AI_PROVIDER_MODE=stub

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_TRANSCRIPTION_MODEL=whisper-1

AUTH_SERVICE_URL=http://localhost:3005
CORE_SERVICE_URL=http://localhost:3007
INTERNAL_API_KEY=
JWT_ACCESS_SECRET=
DASHBOARD_HELPER_KB_PATH=docs/medsphere-role-portal-user-friendly-knowledge-base.txt
MAX_AUDIO_FILE_SIZE_MB=25
UPLOADS_DIR=uploads
PUBLIC_BASE_URL=
VAPI_API_BASE_URL=https://api.vapi.ai
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=

# Docker Compose host-port overrides
MONGODB_PORT=27019
REDIS_PORT=6381

# Used only by docker-compose.yml when Auth/Core run on the host machine.
AUTH_SERVICE_URL_DOCKER=http://host.docker.internal:3005
CORE_SERVICE_URL_DOCKER=http://host.docker.internal:3007
